---
import nav from '../content/data/nav.json';
import Footer from '../components/Footer.astro';
import { url } from '../lib/url';

type Props = {
  title: string;
  transparentHeader?: boolean;
};

const { title, transparentHeader = false } = Astro.props;
const rawPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const basePath = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '');
const pathname = basePath && rawPath.startsWith(basePath) ? (rawPath.slice(basePath.length) || '/') : rawPath;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-cloud text-graphite">
    <header
      id="ll-header"
      class:list={[
        'll-header fixed inset-x-0 top-0 z-30 transition-colors duration-300',
        transparentHeader ? 'bg-black/25 backdrop-blur-sm' : 'bg-paper/95 backdrop-blur shadow-soft'
      ]}
    >
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:py-4">
        <a href={url('/')} class:list={[
          'font-serif text-xl font-bold tracking-tight sm:text-2xl',
          transparentHeader ? 'text-cloud drop-shadow' : 'text-graphite'
        ]}>{nav.brand}</a>
        <nav class="flex items-center gap-1 text-xs font-medium sm:gap-2 sm:text-sm">
          {nav.items.map((it, i) => {
            const active = pathname === it.href || (it.href !== '/' && !it.href.startsWith('/#') && pathname.startsWith(it.href));
            return (
              <>
                {i > 0 && (
                  <span
                    aria-hidden="true"
                    class:list={[
                      'select-none',
                      transparentHeader ? 'text-cloud/40' : 'text-neutral-300'
                    ]}
                  >|</span>
                )}
                <a
                  href={url(it.href)}
                  class:list={[
                    'transition whitespace-nowrap px-1 sm:px-2',
                    transparentHeader
                      ? (active ? 'text-cloud underline underline-offset-4' : 'text-cloud/90 hover:text-cloud')
                      : (active ? 'text-graphite underline underline-offset-4' : 'text-neutral-600 hover:text-graphite')
                  ]}
                >{it.label}</a>
              </>
            );
          })}
        </nav>
      </div>
    </header>

    <slot />

    <Footer />

    <style is:global>
      .ll-header { transition: background-color 300ms ease; }
    </style>
  </body>
</html>
