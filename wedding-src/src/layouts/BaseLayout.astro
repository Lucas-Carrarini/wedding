---
import nav from '../content/data/nav.json';
import Footer from '../components/Footer.astro';
import { url } from '../lib/url';

type Props = {
  title: string;
  transparentHeader?: boolean;
};

const { title, transparentHeader = false } = Astro.props;
const rawPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const basePath = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '');
const pathname = basePath && rawPath.startsWith(basePath) ? (rawPath.slice(basePath.length) || '/') : rawPath;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-cloud text-graphite">
    <header
      id="ll-header"
      class:list={[
        'll-header fixed inset-x-0 top-0 z-30 hidden transition-colors duration-300 md:block',
        transparentHeader ? 'bg-transparent' : 'bg-white/90 backdrop-blur'
      ]}
    >
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <a href={url('/')} class:list={[
          'font-serif text-2xl font-bold tracking-tight',
          transparentHeader ? 'text-white drop-shadow' : 'text-neutral-900'
        ]}>{nav.brand}</a>
        <nav class="flex items-center gap-5 text-sm font-medium">
          {nav.items.map((it) => {
            const active = pathname === it.href || (it.href !== '/' && pathname.startsWith(it.href));
            return (
              <a
                href={url(it.href)}
                class:list={[
                  'transition',
                  transparentHeader
                    ? (active ? 'text-white underline underline-offset-4' : 'text-white/90 hover:text-white')
                    : (active ? 'text-neutral-900 underline underline-offset-4' : 'text-neutral-600 hover:text-neutral-900')
                ]}
              >{it.label}</a>
            );
          })}
        </nav>
      </div>
    </header>

    <button
      id="ll-hamb"
      type="button"
      aria-label="Abrir menu"
      aria-controls="ll-mobile-menu"
      aria-expanded="false"
      class="ll-hamb fixed right-4 top-4 z-50 flex h-11 w-11 items-center justify-center rounded-full shadow-soft backdrop-blur md:hidden"
    >
      <span class="ll-hamb-bars" aria-hidden="true"></span>
    </button>

    <div id="ll-mobile-menu" class="ll-mobile-menu fixed inset-0 z-40 md:hidden" role="dialog" aria-modal="true">
      <div class="ll-mobile-menu__backdrop absolute inset-0 bg-black/40"></div>
      <nav class="ll-mobile-menu__panel absolute right-4 top-4 w-64 rounded-2xl bg-white p-4 pt-16 text-center shadow-soft">
        <ul class="space-y-1">
          {nav.items.map((it) => {
            const active = pathname === it.href || (it.href !== '/' && pathname.startsWith(it.href));
            return (
              <li>
                <a
                  href={url(it.href)}
                  class:list={[
                    'block rounded-xl px-3 py-3 text-base font-medium transition',
                    active ? 'bg-neutral-100 text-neutral-900' : 'text-neutral-700 hover:bg-neutral-50'
                  ]}
                >{it.label}</a>
              </li>
            );
          })}
        </ul>
      </nav>
    </div>

    <slot />

    <Footer />

    <style is:global>
      .ll-header { transition: transform 300ms ease, background-color 300ms ease; will-change: transform; }
      @media (min-width: 768px) {
        .ll-header.ll-header--hidden { transform: translateY(-100%); }
      }

      .ll-hamb {
        background: rgba(255, 255, 255, 0.9);
        transition: background-color 280ms ease, color 280ms ease, transform 280ms ease;
      }
      .ll-hamb[aria-expanded="true"] {
        background: #111827;
      }

      .ll-hamb-bars,
      .ll-hamb-bars::before,
      .ll-hamb-bars::after {
        display: block;
        width: 18px;
        height: 2px;
        background: #111827;
        border-radius: 2px;
        transition: background-color 280ms ease, transform 320ms cubic-bezier(0.22, 1, 0.36, 1), top 320ms cubic-bezier(0.22, 1, 0.36, 1);
      }
      .ll-hamb-bars { position: relative; }
      .ll-hamb-bars::before,
      .ll-hamb-bars::after {
        content: '';
        position: absolute;
        left: 0;
      }
      .ll-hamb-bars::before { top: -6px; }
      .ll-hamb-bars::after  { top:  6px; }

      .ll-hamb[aria-expanded="true"] .ll-hamb-bars { background: transparent; }
      .ll-hamb[aria-expanded="true"] .ll-hamb-bars::before,
      .ll-hamb[aria-expanded="true"] .ll-hamb-bars::after { background: #ffffff; top: 0; }
      .ll-hamb[aria-expanded="true"] .ll-hamb-bars::before { transform: rotate(45deg); }
      .ll-hamb[aria-expanded="true"] .ll-hamb-bars::after  { transform: rotate(-45deg); }

      .ll-mobile-menu {
        opacity: 0;
        pointer-events: none;
        transition: opacity 260ms ease;
      }
      .ll-mobile-menu.ll-mobile-menu--open {
        opacity: 1;
        pointer-events: auto;
      }
      .ll-mobile-menu__backdrop {
        opacity: 0;
        transition: opacity 260ms ease;
      }
      .ll-mobile-menu.ll-mobile-menu--open .ll-mobile-menu__backdrop {
        opacity: 1;
      }
      .ll-mobile-menu__panel {
        transform: translateY(-12px) scale(0.98);
        opacity: 0;
        transform-origin: top right;
        transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1), opacity 260ms ease;
      }
      .ll-mobile-menu.ll-mobile-menu--open .ll-mobile-menu__panel {
        transform: translateY(0) scale(1);
        opacity: 1;
      }
    </style>

    <script is:inline>
      (function () {
        var header = document.getElementById('ll-header');
        if (header) {
          var lastY = window.scrollY;
          var ticking = false;
          var threshold = 80;
          window.addEventListener('scroll', function () {
            if (ticking) return;
            window.requestAnimationFrame(function () {
              var y = window.scrollY;
              var goingDown = y > lastY;
              if (goingDown && y > threshold) {
                header.classList.add('ll-header--hidden');
              } else {
                header.classList.remove('ll-header--hidden');
              }
              lastY = y;
              ticking = false;
            });
            ticking = true;
          }, { passive: true });
        }

        var hamb = document.getElementById('ll-hamb');
        var menu = document.getElementById('ll-mobile-menu');
        var backdrop = menu ? menu.querySelector('.ll-mobile-menu__backdrop') : null;
        function setMenu(open) {
          if (!menu || !hamb) return;
          if (open) {
            menu.classList.add('ll-mobile-menu--open');
            hamb.setAttribute('aria-expanded', 'true');
            hamb.setAttribute('aria-label', 'Fechar menu');
            document.body.style.overflow = 'hidden';
          } else {
            menu.classList.remove('ll-mobile-menu--open');
            hamb.setAttribute('aria-expanded', 'false');
            hamb.setAttribute('aria-label', 'Abrir menu');
            document.body.style.overflow = '';
          }
        }
        function toggleMenu() {
          if (!hamb) return;
          setMenu(hamb.getAttribute('aria-expanded') !== 'true');
        }
        if (hamb) hamb.addEventListener('click', toggleMenu);
        if (backdrop) backdrop.addEventListener('click', function () { setMenu(false); });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && hamb && hamb.getAttribute('aria-expanded') === 'true') setMenu(false);
        });
      })();
    </script>
  </body>
</html>
