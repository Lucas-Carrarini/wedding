---
import footer from '../content/data/footer.json';
import MessageBoardForm from './react/MessageBoardForm';
---

<footer id="recados" class="bg-graphite text-cloud scroll-mt-24">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:py-16">
    <div class="mx-auto w-full max-w-xl">
      <MessageBoardForm
        client:load
        title={footer.messageBoard.title}
        subtitle={footer.messageBoard.subtitle}
        nameLabel={footer.messageBoard.nameLabel}
        namePlaceholder={footer.messageBoard.namePlaceholder}
        messageLabel={footer.messageBoard.messageLabel}
        messagePlaceholder={footer.messageBoard.messagePlaceholder}
        submitLabel={footer.messageBoard.submitLabel}
        sendingLabel={footer.messageBoard.sendingLabel}
        successTitle={footer.messageBoard.successTitle}
        successMessage={footer.messageBoard.successMessage}
        successCloseLabel={footer.messageBoard.successCloseLabel}
        requiredError={footer.messageBoard.requiredError}
      />
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-center text-sm text-cloud/70">
      {footer.credits.lines.map((line, i) => (
        <>
          {i > 0 && <span aria-hidden="true" class="text-cloud/30">-</span>}
          <span>{line}</span>
        </>
      ))}
      <span aria-hidden="true" class="text-cloud/30">-</span>
      <span>
        {footer.credits.madeBy.prefix}{' '}
        <a
          href={footer.credits.madeBy.url}
          target="_blank"
          rel="noreferrer"
          class="text-inherit no-underline transition hover:text-cloud"
          style="color: inherit; text-decoration: none;"
        >{footer.credits.madeBy.name}</a>
      </span>
    </div>
  </div>
</footer>
