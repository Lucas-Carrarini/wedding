---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../content/data/site.json';
import presentesSection from '../content/data/presentes-section.json';
import presentes from '../content/data/presentes.json';
import PresentesIntro from '../content/sections/presentes-intro.md';
import PresentesPreferencia from '../content/sections/presentes-preferencia.md';
import GiftsModalButton from '../components/react/GiftsModalButton';
import CopyPixButton from '../components/react/CopyPixButton';
import images from '../content/data/images.json';
import { resolveImage } from '../lib/image';

const title = `${presentesSection.title} - ${site.couple.names}`;

const qrUrl = resolveImage(images.pix.qrcode);

const giftsList = presentes.map((g: { id: string; nome: string; valor: number }) => ({
  nome: g.nome,
  valor: g.valor,
}));
---

<BaseLayout title={title}>
  <style>
    @import url('../styles/global.css');

    .ll-qr-crop {
      width: 100%;
      aspect-ratio: 1 / 1;
      background-repeat: no-repeat;
      background-size: contain;
      background-position: center center;
    }
  </style>

  <main>
    <section class="bg-cloud">
      <div class="mx-auto max-w-5xl px-4 pb-16 pt-24 sm:pb-20 sm:pt-28">
        <div class="text-center">
          <h1 class="font-serif text-3xl font-bold tracking-tight text-graphite sm:text-4xl">{presentesSection.title}</h1>
        </div>

        <div class="mt-10 grid gap-10 sm:grid-cols-[1fr_320px] sm:items-start">
          <div class="space-y-8">
            <div class="prose prose-neutral max-w-none">
              <PresentesIntro />
            </div>
            <div class="prose prose-neutral max-w-none">
              <PresentesPreferencia />
            </div>
            <div class="flex justify-center">
              <GiftsModalButton
                client:load
                openLabel={presentesSection.seeListButton}
                closeLabel={presentesSection.closeModalButton}
                modalTitle={presentesSection.modalTitle}
                wantToGiftText={presentesSection.wantToGiftText}
                whatsappLabel={presentesSection.whatsappButton}
                whatsappUrl={presentesSection.whatsappUrl}
                gifts={giftsList}
              />
            </div>
          </div>

          <div class="rounded-3xl bg-paper p-5 shadow-soft sm:p-6">
            <div class="text-center text-xs font-medium uppercase tracking-[0.18em] text-neutral-500">{presentesSection.qrHelper}</div>
            <div class="mt-4 overflow-hidden rounded-2xl bg-paper">
              <div
                role="img"
                aria-label={presentesSection.qrHelper}
                class="ll-qr-crop"
                style={`background-image: url(${qrUrl});`}
              ></div>
            </div>

            <div class="mt-5">
              <CopyPixButton
                client:load
                payload={presentesSection.pixPayload}
                cpf={presentesSection.pixCpf}
                copiedLabel={presentesSection.copiedLabel}
              />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
