---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../content/data/site.json';
import Countdown from '../components/react/Countdown';
import prewedding from '../content/data/prewedding.json';
import PhotoCarousel from '../components/react/PhotoCarousel';
import Historia from '../content/sections/historia.md';
import historiaSection from '../content/data/historia-section.json';
import localizacao from '../content/data/localizacao.json';
import AddToCalendarLink from '../components/react/AddToCalendarLink';
import manualItems from '../content/data/manual.json';
import manualSection from '../content/data/manual-section.json';
import ManualGrid from '../components/react/ManualGrid';
import cronograma from '../content/data/cronograma.json';
import images from '../content/data/images.json';
import { url } from '../lib/url';
import { resolveImage } from '../lib/image';

const title = `${site.couple.names} - ${site.wedding.dateDisplay}`;

const heroDesktopUrl = resolveImage(images.hero.desktop);
const heroMobileUrl = resolveImage(images.hero.mobile);
const valeImageUrl = resolveImage(images.localizacao.vale);

const preweddingImages = prewedding.imageIds.map((id: string) => {
  const entry = (images.prewedding as Record<string, { real: string; mockSize: string; alt?: string }>)[id];
  return { id, url: resolveImage(entry), alt: entry?.alt ?? '' };
});

const manualModules = import.meta.glob('../content/sections/manual/*.md', { eager: true }) as Record<string, any>;

const manualWithContent = await Promise.all(
  manualItems.map(async (it: { id: string; title: string; redirectTo?: string; redirectLabel?: string }) => {
    const key = `../content/sections/manual/${it.id}.md`;
    const mod = manualModules[key];
    const html = mod && typeof mod.compiledContent === 'function' ? await mod.compiledContent() : '';
    const imgEntry = (images.manual as Record<string, { real: string; mockSize: string }>)[it.id];
    const iconUrl = imgEntry ? resolveImage(imgEntry) : '';
    return { ...it, iconUrl, contentHtml: html, redirectTo: it.redirectTo ? url(it.redirectTo) : undefined };
  })
);

const cronogramaModules = import.meta.glob('../content/sections/cronograma/*.md', { eager: true }) as Record<string, any>;

const cronogramaWithContent = await Promise.all(
  cronograma.items.map(async (it: { id: string; time: string; label: string }) => {
    const key = `../content/sections/cronograma/${it.id}.md`;
    const mod = cronogramaModules[key];
    const html = mod && typeof mod.compiledContent === 'function' ? await mod.compiledContent() : '';
    return { ...it, contentHtml: html };
  })
);
---

<BaseLayout title={title} transparentHeader={true}>
  <style>
    @import url('../styles/global.css');
  </style>

  <main>
    <section class="relative min-h-screen">
      <picture class="absolute inset-0">
        <source media="(min-width: 768px)" srcset={heroDesktopUrl} />
        <img
          src={heroMobileUrl}
          alt=""
          class="h-full w-full object-cover object-center"
          loading="eager"
        />
      </picture>

      <div class="absolute inset-0 bg-black/35"></div>

      <div class="relative z-10 flex min-h-screen items-center justify-center px-4">
        <div class="text-center text-cloud">
          <div class="relative mx-auto inline-flex h-28 w-28 items-center justify-center sm:h-36 sm:w-36">
            <span
              aria-hidden="true"
              class="pointer-events-none absolute bottom-1/4 left-1/4 right-0 top-0 border-r-2 border-t-2 border-cloud"
            ></span>
            <span
              aria-hidden="true"
              class="pointer-events-none absolute bottom-0 left-0 right-1/4 top-1/4 border-b-2 border-l-2 border-cloud"
            ></span>
            <span class="relative font-serif text-5xl font-bold tracking-tight drop-shadow-sm sm:text-6xl">
              {site.hero.overlay.logo}
            </span>
          </div>
          <div class="mt-6 font-serif text-3xl font-bold tracking-tight drop-shadow-sm sm:text-4xl">
            {site.hero.overlay.fullName}
          </div>
          <div class="mt-3 text-xs font-semibold tracking-[0.35em] text-cloud/90">
            {site.hero.overlay.date}
          </div>
        </div>
      </div>
    </section>

    <Countdown
      client:load
      targetISO={site.wedding.targetISO}
      title={site.countdown.title}
      labels={site.countdown.labels}
    />

    <section id="historia" class="bg-paper scroll-mt-24">
      <div class="mx-auto max-w-6xl px-4 pt-16 sm:pt-20">
        <div class="text-center">
          <h2 class="font-serif text-3xl font-bold tracking-tight text-graphite sm:text-4xl">{historiaSection.title}</h2>
        </div>
      </div>
      <div class="mt-10">
        <PhotoCarousel client:load autoplayMs={prewedding.autoplayMs} images={preweddingImages} />
      </div>
      <div class="mx-auto max-w-6xl px-4 pb-16 sm:pb-20">
        <div class="prose prose-neutral mx-auto mt-10 max-w-3xl prose-headings:font-serif prose-headings:tracking-tight prose-h2:text-2xl">
          <Historia />
        </div>
      </div>
    </section>

    <section id="localizacao" class="bg-cloud scroll-mt-24">
      <div class="mx-auto max-w-6xl px-4 py-16 sm:py-20">
        <div class="text-center">
          <h2 class="font-serif text-3xl font-bold tracking-tight text-graphite sm:text-4xl">{localizacao.title}</h2>
          <p class="mx-auto mt-6 max-w-2xl text-base text-graphite sm:text-lg">
            Esse dia especial acontecerá na casa de festas Vale dos Sonhos (<a
              href="https://www.instagram.com/valedossonhos"
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold text-olive underline decoration-olive/30 underline-offset-4 transition hover:decoration-olive"
            >@valedossonhos</a>).
          </p>
        </div>

        <div class="mt-10 grid gap-6 lg:grid-cols-2 lg:items-stretch">
          <div class="overflow-hidden rounded-3xl bg-paper shadow-soft">
            <iframe
              title="Mapa"
              src={localizacao.map.embedUrl}
              class="h-[420px] w-full"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>

          <div class="flex flex-col justify-center rounded-3xl bg-paper p-6 shadow-soft sm:p-8">
            <div class="space-y-5">
              <div>
                <div class="text-[11px] font-medium uppercase tracking-[0.18em] text-neutral-500">{localizacao.labels.arrivalLabel}</div>
                <div class="mt-1 font-serif text-4xl font-bold text-graphite">{localizacao.recommendedArrival}</div>
              </div>
              <div>
                <div class="text-[11px] font-medium uppercase tracking-[0.18em] text-neutral-500">{localizacao.labels.addressLabel}</div>
                <div class="mt-1 text-base text-neutral-800">{localizacao.addressShort}</div>
              </div>
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 shrink-0 text-graphite" aria-hidden="true">
                  <rect width="18" height="18" x="3" y="3" rx="2" />
                  <path d="M9 17V7h4a3 3 0 0 1 0 6H9" />
                </svg>
                <span class="text-sm text-neutral-700">{localizacao.labels.parkingLabel}</span>
              </div>
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 shrink-0 text-graphite" aria-hidden="true">
                  <path d="M18 20V6a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v14" />
                  <path d="M2 20h20" />
                  <path d="M14 12v.01" />
                </svg>
                <span class="text-sm text-neutral-700">{localizacao.labels.gateLabel}</span>
              </div>
            </div>

            <div class="mt-8 flex flex-wrap gap-3">
              <AddToCalendarLink
                client:load
                label={localizacao.labels.addToCalendar}
                title={localizacao.event.eventTitle}
                location={localizacao.addressFull}
                description={localizacao.event.eventDescription}
                startISO={site.wedding.targetISO}
                endISO={'2026-07-26T20:00:00-03:00'}
                fileName={localizacao.event.icsFileName}
              />
              <a
                class="rounded-full bg-graphite px-5 py-3 text-sm font-semibold text-cloud shadow-soft transition hover:bg-graphite/90"
                href={localizacao.map.googleMapsQueryUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                {localizacao.labels.openInMaps}
              </a>
            </div>
          </div>
        </div>

        <div class="mt-10 overflow-hidden rounded-3xl bg-paper shadow-soft">
          <img
            src={valeImageUrl}
            alt={localizacao.venueName}
            class="block w-full"
            style="aspect-ratio: 16 / 9; object-fit: cover;"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <section id="manual" class="bg-paper scroll-mt-24">
      <div class="mx-auto max-w-6xl px-4 py-16 sm:py-20">
        <div class="text-center">
          <h2 class="font-serif text-3xl font-bold tracking-tight text-graphite sm:text-4xl">{manualSection.title}</h2>
          {manualSection.description && (
            <p class="mx-auto mt-4 max-w-2xl text-base text-neutral-700 sm:text-lg">{manualSection.description}</p>
          )}
        </div>

        <div class="mt-10">
          <ManualGrid client:load items={manualWithContent} />
        </div>
      </div>
    </section>

    <section id="cronograma" class="bg-cloud scroll-mt-24">
      <div class="mx-auto max-w-4xl px-4 py-16 sm:py-20">
        <div class="text-center">
          <h2 class="font-serif text-3xl font-bold tracking-tight text-graphite sm:text-4xl">{cronograma.title}</h2>
          <p class="mt-3 text-sm text-neutral-600">{cronograma.hidden ? cronograma.hiddenSubtitle : cronograma.subtitle}</p>
        </div>

        {!cronograma.hidden && (
          <ol class="mt-12 space-y-10">
            {cronogramaWithContent.map((it) => (
              <li class="grid gap-4 sm:grid-cols-[120px_1fr] sm:items-center sm:gap-8">
                <div class="font-serif text-4xl font-bold leading-none text-brand-500 sm:text-5xl">{it.time}</div>
                <div class="rounded-2xl bg-paper p-6 shadow-soft sm:p-8">
                  <div class="font-serif text-xl font-bold text-graphite sm:text-2xl">{it.label}</div>
                  <div
                    class="prose prose-neutral mt-3 max-w-none"
                    set:html={it.contentHtml}
                  />
                </div>
              </li>
            ))}
          </ol>
        )}
      </div>
    </section>

  </main>
</BaseLayout>
